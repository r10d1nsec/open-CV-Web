# Folio — environment variables. Copy to .env.local and fill in.
# Never commit .env.local (it's gitignored).

# ----------------------------------------------------------------------------
# Site — público (dominio donde se despliega). En Vercel ponlo a tu dominio.
# Se usa para URLs absolutas (QR, card, emails). Sin esto cae a localhost.
# ----------------------------------------------------------------------------
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# ----------------------------------------------------------------------------
# Supabase — REQUERIDO para auth + base de datos.
# Crea un proyecto gratis en https://supabase.com → Settings → API.
# ----------------------------------------------------------------------------
# Project URL — https://<project-ref>.supabase.co
NEXT_PUBLIC_SUPABASE_URL=

# anon / public key — seguro exponer al navegador.
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# service_role key — SOLO SERVIDOR. Nunca al navegador. Bypassa RLS.
# Usado para migraciones, seed y borrado de cuenta (admin).
SUPABASE_SERVICE_ROLE_KEY=

# ----------------------------------------------------------------------------
# Email transaccional (opcional) — Resend. Sin esto, el formulario de contacto
# y las reservas guardan en DB pero no envían email.
# ----------------------------------------------------------------------------
# RESEND_API_KEY=
# Remitente. Debe ser de un dominio verificado en Resend (DKIM/SPF).
# EMAIL_FROM=Folio <hi@tudominio.com>

# ----------------------------------------------------------------------------
# Google OAuth (opcional) — login con Google. El código está tras un flag.
# Configura el OAuth Client en Google Cloud Console + Supabase Dashboard,
# luego pon esto a 'true'. Ver docs/adr/0005-google-oauth.md.
# ----------------------------------------------------------------------------
# NEXT_PUBLIC_ENABLE_GOOGLE_OAUTH=true

# ----------------------------------------------------------------------------
# Rate-limit multi-instancia (opcional) — Upstash Redis. Sin esto se usa un
# fallback en memoria (suficiente para dev/single-instance).
# ----------------------------------------------------------------------------
# UPSTASH_REDIS_REST_URL=
# UPSTASH_REDIS_REST_TOKEN=

# ----------------------------------------------------------------------------
# Observabilidad (opcional) — Sentry. DSN público. Solo captura en producción.
# ----------------------------------------------------------------------------
# NEXT_PUBLIC_SENTRY_DSN=
